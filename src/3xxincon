3xxincon() {
  if [[ -z "$1" ]]; then
    echo "Usage:"
    echo "  3xxincon subs_list.txt    # Scan & save to 3xxincon.txt"
    return
  fi

  local input_file="$1"
  
  if [[ ! -f "$input_file" ]]; then
    echo "[!] Error: Input file '$input_file' not found"
    return
  fi

  python3 "$BFH_PATH/pysrc/3xxincon.py" -f "$input_file"
}